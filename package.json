{
  "name": "@orderly/secclaw",
  "version": "2.0.0",
  "description": "Security, oversight, and integrity layer for autonomous trading agents on Orderly Network",
  "type": "module",
  "main": "dist/daemon.js",
  "bin": {
    "secclaw-preinstall": "dist/cli/preinstall.js"
  },
  "scripts": {
    "start": "tsx src/daemon.ts",
    "check": "tsx src/daemon.ts --once",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "secclaw:attest": "tsx scripts/attest.ts",
    "secclaw:preinstall": "tsx src/cli/preinstall.ts",
    "secclaw:sign-manifest": "tsx scripts/sign-manifest.ts"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "viem": "^2.47.6",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
